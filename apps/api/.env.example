# API
PORT=4000
# Comma-separated list of allowed CORS origins for the web app
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=claims_user
DB_PASSWORD=claims_pass
DB_NAME=claims_db
# Auto-create/update schema from entities on startup. Handy for local dev, but it
# can DROP columns/tables to match entities — NEVER enable it in builds/prod.
# Local dev: leave true. Builds/prod/CI: set false and use migrations instead:
#   pnpm migration:run     apply pending migrations (deploy step / fresh CI DB)
#   pnpm migration:generate src/migrations/<Name>   after changing an entity
#   pnpm db:seed           populate sample data
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT auth
# JWT_SECRET is required — set it to a long random string (the API fails to boot without it).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d
